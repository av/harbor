  command: cd services/boost && python3 -c "import tomllib;g=tomllib.load(open('pyproject.toml','rb'))['dependency-groups']['dev'];assert {'pytest','pytest-asyncio','pytest-xdist','anthropic'} <= set(g), g"
  tags: [implemented]
